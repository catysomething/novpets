generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Pet {
  id          String    @id @default(uuid())
  name        String
  animalType  String
  ownerName   String
  dateOfBirth DateTime
  deletedAt   DateTime?
  vaccines    Vaccine[]
  allergies   Allergy[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([deletedAt])
}

// Track changes to records so we don't lose data on in-place changes
model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  changes    Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Catalog of medical record kinds (VACCINE, ALLERGY, …). `id` is the stable code used in APIs and FKs.
model MedicalRecordType {
  id            String    @id
  name          String
  payloadSchema Json
  /// Which physical table rows are stored in (`vaccine` | `allergy` today).
  storageModel  String
  vaccines      Vaccine[] @relation("VaccineMedicalRecordType")
  allergies     Allergy[] @relation("AllergyMedicalRecordType")

  @@map("MedicalRecordTypes")
}

model Vaccine {
  id               String            @id @default(uuid())
  petId            String
  pet              Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  recordTypeId     String
  recordType       MedicalRecordType @relation("VaccineMedicalRecordType", fields: [recordTypeId], references: [id])
  vaccineName      String
  dateAdministered DateTime
  deletedAt        DateTime?
  removalNote      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([petId])
  @@index([recordTypeId])
  @@index([deletedAt])
}

model Allergy {
  id           String            @id @default(uuid())
  petId        String
  pet          Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  recordTypeId String
  recordType   MedicalRecordType @relation("AllergyMedicalRecordType", fields: [recordTypeId], references: [id])
  allergyName  String
  reactions    String
  severity     AllergySeverity
  deletedAt    DateTime?
  removalNote  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([petId])
  @@index([recordTypeId])
  @@index([deletedAt])
}

enum AllergySeverity {
  mild
  severe
}
